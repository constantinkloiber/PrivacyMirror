<Window Icon="app.ico"
        x:Class="PrivacyMirror.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PrivacyMirror"
        Height="560" Width="440"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A"
        Closing="MainWindow_Closing">

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- Header -->
      <RowDefinition Height="Auto"/>  <!-- Monitor-Bereich -->
      <RowDefinition Height="Auto"/>  <!-- Trennlinie -->
      <RowDefinition Height="Auto"/>  <!-- Fenster-Label + Refresh -->
      <RowDefinition Height="*"/>     <!-- Fensterliste -->
      <RowDefinition Height="Auto"/>  <!-- Fenster holen -->
      <RowDefinition Height="Auto"/>  <!-- Start/Stop Button -->
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,0,0,20">
      <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
        <!-- Shield + mirror icon drawn with paths -->
        <Viewbox Width="28" Height="28" Margin="0,0,8,0">
          <Canvas Width="24" Height="24">
            <!-- Monitor -->
            <Rectangle Canvas.Left="1" Canvas.Top="3" Width="22" Height="15"
                       RadiusX="2" RadiusY="2"
                       Stroke="White" StrokeThickness="1.5" Fill="Transparent"/>
            <!-- Screen shine -->
            <Rectangle Canvas.Left="3" Canvas.Top="5" Width="18" Height="11"
                       Fill="#334155"/>
            <!-- Reflection lines on screen -->
            <Line X1="6" Y1="8"  X2="11" Y2="8"  Stroke="#60A5FA" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            <Line X1="6" Y1="11" X2="14" Y2="11" Stroke="#60A5FA" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            <Line X1="6" Y1="14" X2="10" Y2="14" Stroke="#60A5FA" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            <!-- Stand -->
            <Line X1="12" Y1="18" X2="12" Y2="21" Stroke="White" StrokeThickness="1.5"/>
            <Line X1="8"  Y1="21" X2="16" Y2="21" Stroke="White" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
          </Canvas>
        </Viewbox>
        <TextBlock Text="PrivacyMirror" FontSize="22" FontWeight="Bold"
                   Foreground="White" VerticalAlignment="Center"/>
      </StackPanel>
      <TextBlock Text="Reserviere einen Monitor und spiegele beliebige Fenster darauf."
                 FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap"/>
    </StackPanel>

    <!-- Monitor-Bereich -->
    <Grid Grid.Row="1" Margin="0,0,0,16">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                 Text="1. Beamer-Monitor wählen und reservieren:"
                 Foreground="#94A3B8" FontSize="12" Margin="0,0,0,6"/>

      <ComboBox Grid.Row="1" Grid.Column="0" x:Name="MonitorComboBox"
                FontSize="13" Height="36" Margin="0,0,8,0" IsEnabled="True">
        <ComboBox.Style>
          <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
              <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                  <Grid>
                    <ToggleButton x:Name="ToggleButton"
                      Background="#1E293B" Foreground="White"
                      BorderThickness="0"
                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                      ClickMode="Press">
                      <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                          <Border Background="{TemplateBinding Background}"
                                  CornerRadius="4" Padding="10,0">
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                              </Grid.ColumnDefinitions>
                              <ContentPresenter Grid.Column="0"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                              <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                                    Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                          </Border>
                        </ControlTemplate>
                      </ToggleButton.Template>
                    </ToggleButton>
                    <Popup x:Name="Popup" Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True" Focusable="False">
                      <Border Background="#1E293B" BorderThickness="0" CornerRadius="4"
                              MinWidth="{TemplateBinding ActualWidth}"
                              MaxHeight="{TemplateBinding MaxDropDownHeight}">
                        <ScrollViewer>
                          <ItemsPresenter/>
                        </ScrollViewer>
                      </Border>
                    </Popup>
                  </Grid>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </Style>
        </ComboBox.Style>
        <ComboBox.ItemContainerStyle>
          <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
              <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                  <Border x:Name="Bd" Background="{TemplateBinding Background}"
                          Padding="{TemplateBinding Padding}">
                    <ContentPresenter/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="Bd" Property="Background" Value="#334155"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                      <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </Style>
        </ComboBox.ItemContainerStyle>
      </ComboBox>

      <Button Grid.Row="1" Grid.Column="1"
              x:Name="ReserveButton"
              Content="⬛  Reservieren"
              Height="36" Padding="12,0"
              Click="ReserveMonitor_Click"/>
    </Grid>

    <!-- Status-Badge -->
    <Border Grid.Row="2" x:Name="StatusBadge"
            Background="#1E293B" CornerRadius="6" Padding="12,8"
            Margin="0,0,0,16">
      <TextBlock x:Name="StatusText"
                 Text="⚪  Kein Monitor reserviert"
                 Foreground="#64748B" FontSize="12"/>
    </Border>

    <!-- Fenster-Label + Refresh -->
    <Grid Grid.Row="3" Margin="0,0,0,8">
      <TextBlock Text="2. Fenster zum Spiegeln wählen:"
                 Foreground="#94A3B8" FontSize="12"
                 VerticalAlignment="Center"/>
      <Button HorizontalAlignment="Right" Content="↻ Aktualisieren"
              Padding="10,4" FontSize="11"
              Click="RefreshWindows_Click"/>
    </Grid>

    <!-- Fensterliste -->
    <ListBox Grid.Row="4" x:Name="WindowListBox"
             Background="#1E293B" BorderThickness="0"
             Foreground="White" FontSize="13"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             IsEnabled="False"
             SelectionChanged="WindowListBox_SelectionChanged">
      <ListBox.Resources>
        <Style TargetType="ListBoxItem">
          <Setter Property="Padding" Value="12,8"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ListBoxItem">
                <Border x:Name="Bd" Background="Transparent"
                        CornerRadius="6" Margin="2" Padding="12,8">
                  <ContentPresenter/>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#334155"/>
                  </Trigger>
                  <Trigger Property="IsSelected" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </ListBox.Resources>
    </ListBox>

    <!-- Fenster holen -->
    <Button Grid.Row="5" x:Name="GatherButton" Content="Alle Fenster auf Hauptmonitor holen" Height="34" FontSize="12" Margin="0,10,0,2" Background="#334155" Click="GatherWindows_Click"/>

    <!-- Start/Stop + Freigabe -->
    <Grid Grid.Row="6" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Button Grid.Column="0" x:Name="MirrorButton"
              Content="▶  Spiegelung starten"
              Height="40" FontSize="14" Margin="0,0,8,0"
              IsEnabled="False"
              Click="StartMirror_Click"/>

      <Button Grid.Column="1" x:Name="ReleaseButton"
              Content="✕  Freigeben"
              Height="40" Padding="14,0"
              Background="#DC2626" IsEnabled="False"
              Click="ReleaseMonitor_Click"/>
    </Grid>
  </Grid>
</Window>
