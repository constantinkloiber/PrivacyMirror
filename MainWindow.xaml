<Window Icon="app.ico"
        x:Class="PrivacyMirror.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PrivacyMirror"
        Height="600" Width="440"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A"
        Closing="MainWindow_Closing">

  <Window.Resources>

    <!-- Standard-Button-Stil -->
    <Style TargetType="Button">
      <Setter Property="Background"      Value="#1E293B"/>
      <Setter Property="Foreground"      Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="FontFamily"      Value="Segoe UI"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#334155"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- CheckBox-Stil für Monitor-Liste -->
    <Style x:Key="MonitorCheckStyle" TargetType="CheckBox">
      <Setter Property="Foreground"             Value="#CBD5E1"/>
      <Setter Property="FontSize"               Value="13"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Cursor"                 Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <Border x:Name="Row" Background="Transparent"
                    CornerRadius="5" Padding="10,9" Margin="2,1">
              <StackPanel Orientation="Horizontal">
                <Border x:Name="Box" Width="16" Height="16"
                        CornerRadius="4" BorderThickness="1.5"
                        BorderBrush="#475569" Background="Transparent"
                        VerticalAlignment="Center" Margin="0,0,10,0">
                  <Path x:Name="Check"
                        Data="M 2 8 L 6 12 L 14 4"
                        Stroke="#38BDF8" StrokeThickness="2"
                        StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                        Visibility="Collapsed"/>
                </Border>
                <ContentPresenter VerticalAlignment="Center"/>
              </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Box"   Property="Background"   Value="#1E3A5F"/>
                <Setter TargetName="Box"   Property="BorderBrush"  Value="#38BDF8"/>
                <Setter TargetName="Check" Property="Visibility"   Value="Visible"/>
                <Setter TargetName="Row"   Property="Background"   Value="#162032"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Row" Property="Background" Value="#1E293B"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </Window.Resources>

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- Header -->
      <RowDefinition Height="Auto"/>  <!-- Monitor-Label + Aktualisieren -->
      <RowDefinition Height="Auto"/>  <!-- Monitor-Liste -->
      <RowDefinition Height="Auto"/>  <!-- Status-Badge -->
      <RowDefinition Height="Auto"/>  <!-- Fenster-Label + Refresh -->
      <RowDefinition Height="*"/>     <!-- Fensterliste -->
      <RowDefinition Height="Auto"/>  <!-- Fenster holen -->
      <RowDefinition Height="Auto"/>  <!-- Start/Stop + Freigabe -->
    </Grid.RowDefinitions>

    <!-- ── Header ─────────────────────────────────────────────────────── -->
    <StackPanel Grid.Row="0" Margin="0,0,0,20">
      <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
        <Viewbox Width="28" Height="28" Margin="0,0,8,0">
          <Canvas Width="24" Height="24">
            <Rectangle Canvas.Left="1" Canvas.Top="3" Width="22" Height="15"
                       RadiusX="2" RadiusY="2"
                       Stroke="White" StrokeThickness="1.5" Fill="Transparent"/>
            <Rectangle Canvas.Left="3" Canvas.Top="5" Width="18" Height="11"
                       Fill="#334155"/>
            <Line X1="6"  Y1="8"  X2="11" Y2="8"  Stroke="#60A5FA" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            <Line X1="6"  Y1="11" X2="14" Y2="11" Stroke="#60A5FA" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            <Line X1="6"  Y1="14" X2="10" Y2="14" Stroke="#60A5FA" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            <Line X1="12" Y1="18" X2="12" Y2="21" Stroke="White" StrokeThickness="1.5"/>
            <Line X1="8"  Y1="21" X2="16" Y2="21" Stroke="White" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
          </Canvas>
        </Viewbox>
        <TextBlock Text="PrivacyMirror" FontSize="22" FontWeight="Bold"
                   Foreground="White" VerticalAlignment="Center"/>
      </StackPanel>
      <TextBlock Text="Hake Monitore ab, um sie zu schwärzen. Dann Fenster wählen und spiegeln."
                 FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap"/>
    </StackPanel>

    <!-- ── Monitor-Label + Aktualisieren ─────────────────────────────── -->
    <Grid Grid.Row="1" Margin="0,0,0,8">
      <TextBlock Text="1. Beamer-Monitor(e) wählen:"
                 Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
      <Button HorizontalAlignment="Right" Content="↻ Aktualisieren"
              Padding="10,4" FontSize="11"
              Click="RefreshMonitors_Click"/>
    </Grid>

    <!-- ── Monitor-Liste (Checkboxen) ────────────────────────────────── -->
    <Border Grid.Row="2" Background="#1E293B" CornerRadius="6"
            Margin="0,0,0,12">
      <ItemsControl x:Name="MonitorList" Padding="4">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <CheckBox Style="{StaticResource MonitorCheckStyle}"
                      IsChecked="{Binding IsChecked, Mode=TwoWay}"
                      Content="{Binding Label}"
                      Click="MonitorCheckBox_Click"/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Border>

    <!-- ── Status-Badge ───────────────────────────────────────────────── -->
    <Border Grid.Row="3" x:Name="StatusBadge"
            Background="#1E293B" CornerRadius="6" Padding="12,8"
            Margin="0,0,0,16">
      <TextBlock x:Name="StatusText"
                 Text="⚪  Kein Monitor reserviert"
                 Foreground="#64748B" FontSize="12"/>
    </Border>

    <!-- ── Fenster-Label + Refresh ────────────────────────────────────── -->
    <Grid Grid.Row="4" Margin="0,0,0,8">
      <TextBlock Text="2. Fenster zum Spiegeln wählen:"
                 Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
      <Button HorizontalAlignment="Right" Content="↻ Aktualisieren"
              Padding="10,4" FontSize="11"
              Click="RefreshWindows_Click"/>
    </Grid>

    <!-- ── Fensterliste ───────────────────────────────────────────────── -->
    <ListBox Grid.Row="5" x:Name="WindowListBox"
             Background="#1E293B" BorderThickness="0"
             Foreground="White" FontSize="13"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             IsEnabled="False"
             SelectionChanged="WindowListBox_SelectionChanged">
      <ListBox.Resources>
        <Style TargetType="ListBoxItem">
          <Setter Property="Padding" Value="12,8"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ListBoxItem">
                <Border x:Name="Bd" Background="Transparent"
                        CornerRadius="6" Margin="2" Padding="12,8">
                  <ContentPresenter/>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#334155"/>
                  </Trigger>
                  <Trigger Property="IsSelected" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </ListBox.Resources>
    </ListBox>

    <!-- ── Fenster einsammeln ─────────────────────────────────────────── -->
    <Button Grid.Row="6" x:Name="GatherButton"
            Content="Alle Fenster auf Hauptmonitor holen"
            Height="34" FontSize="12" Margin="0,10,0,2"
            Background="#334155" IsEnabled="False"
            Click="GatherWindows_Click"/>

    <!-- ── Spiegelung + Freigabe ──────────────────────────────────────── -->
    <Grid Grid.Row="7" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Button Grid.Column="0" x:Name="MirrorButton"
              Content="▶  Spiegelung starten"
              Height="40" FontSize="14" Margin="0,0,8,0"
              IsEnabled="False"
              Click="StartMirror_Click"/>

      <Button Grid.Column="1" x:Name="ReleaseButton"
              Content="✕  Alle freigeben"
              Height="40" Padding="14,0"
              Background="#DC2626" IsEnabled="False"
              Click="ReleaseMonitor_Click"/>
    </Grid>
  </Grid>
</Window>
